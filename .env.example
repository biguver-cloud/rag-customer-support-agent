# OpenAI API Key
# https://platform.openai.com/api-keys で取得したキーを設定してください
# このファイルを .env にコピーして使用してください
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ログ閲覧API認証キー（推測されにくい文字列を設定してください）
ADMIN_API_KEY="your-secret-admin-key"

# ログAPIの有効化フラグ（本番では false を推奨）
ENABLE_LOG_API="true"

# CORSで許可するオリジン（カンマ区切りで複数指定可能）
# 開発環境例: http://localhost:8080,http://localhost:3000
# 本番環境例: https://your-app.run.app
ALLOWED_ORIGINS="http://localhost:8080"
